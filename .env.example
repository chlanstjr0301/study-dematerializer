# ─── Paths ─────────────────────────────────────────────────────────────────
# Use absolute path in production. Relative works for local dev.
GONGHAEBUN_DATA_ROOT=data/gonghaebun/default
# Optional overrides (default to sub-paths of DATA_ROOT):
GONGHAEBUN_BANK_ROOT=data/gonghaebun/default/banks
GONGHAEBUN_RUNS_DIR=data/gonghaebun/default/runs
GONGHAEBUN_STUDY_MD=data/gonghaebun/default/STUDY.md
GONGHAEBUN_SOURCES_DIR=data/gonghaebun/default/sources

# ─── Grader ────────────────────────────────────────────────────────────────
# Default grader: mock (safe, no API key) | llm (requires OPENAI_API_KEY + LLM_DISABLED=0)
GONGHAEBUN_GRADER=mock

# ─── LLM Configuration ────────────────────────────────────────────────────
# LLM master switch: 1=disabled (safe default), 0=enabled
# To enable real LLM: set DISABLED=0, PROVIDER=openai, and OPENAI_API_KEY
# Cost: ~10 API calls per study session (gpt-5.5)
GONGHAEBUN_LLM_DISABLED=1
# LLM provider: mock (fixture-based, no API) | openai (requires API key)
GONGHAEBUN_LLM_PROVIDER=mock
# LLM model (only used when provider=openai)
GONGHAEBUN_LLM_MODEL=gpt-5.5
# Per-call timeout (seconds)
GONGHAEBUN_LLM_TIMEOUT_SECONDS=30
# Max LLM calls per session (cost guard)
GONGHAEBUN_LLM_MAX_CALLS_PER_SESSION=20

# ─── Server ────────────────────────────────────────────────────────────────
# Production: set API_HOST=0.0.0.0 to accept external connections
GONGHAEBUN_API_HOST=127.0.0.1
GONGHAEBUN_API_PORT=8000
# Comma-separated allowed CORS origins (strip whitespace, no empty values)
# Local dev: Vite is on 5173. Production: your server's origin or IP.
GONGHAEBUN_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174
# Set to 1 to serve apps/web/dist/ as SPA (requires: cd apps/web && npm run build)
GONGHAEBUN_SERVE_FRONTEND=1

# ─── Secrets (never commit real values) ────────────────────────────────────
# Required only when GONGHAEBUN_LLM_DISABLED=0
OPENAI_API_KEY=
